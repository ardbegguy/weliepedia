# Welcome to Weliepedia Backend Configuration
#
# This file contains environment variables required for the server to run.
# NEVER commit this file to version control with real API keys.
# 
# To use:
# 1. Copy this file to .env (without the .example extension)
# 2. Replace the placeholder values with your actual credentials
# 3. Add .env to your .gitignore file

# GROQ_API_KEY - Your Groq API key
# Get one at: https://console.groq.com/keys
# Required for accessing Groq's AI models
GROQ_API_KEY=gsk_QHhY17OQKv4Qj0wC9mB565F80B3F6F

# PORT - The port the server will listen on
# Default: 3000 (common for development)
PORT=3000

# LOG_LEVEL - Sets the logging verbosity (optional)
# Options: debug, info, warn, error
# Default: info
# LOG_LEVEL=info
